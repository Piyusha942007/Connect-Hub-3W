# Backend server port
PORT=5000

# MongoDB Connection URI (Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskplanet_social_feed?retryWrites=true&w=majority

# JWT Secret Key for token signing
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_secure

# Client URL (frontend) for CORS configuration
CLIENT_URL=http://localhost:5173

# Cloudinary - Cloud image storage (persistent, survives server restarts)
# Sign up free at https://cloudinary.com and get credentials from your Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
